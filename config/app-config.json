  "auth": {
    "enabled": true,
    "methods": [
      {
        "type": "email_password",
        "enabled": true,
        "passwordMinLength": 8,
        "requireUppercase": true,
        "requireNumber": true
      },
      {
        "type": "magic_link",
        "enabled": true,
        "expiresInMinutes": 15
      }
    ],
    "jwt": {
      "expiresIn": "7d",
      "refreshEnabled": true
    },
    "userScoped": true
  },

  "database": {
    "entities": {
      "projects": {
        "tableName": "projects",
        "userScoped": true,
        "fields": {
          "id": { "type": "uuid", "primaryKey": true, "auto": true },
          "name": { "type": "string", "required": true, "maxLength": 255 },
          "description": { "type": "text", "required": false },
          "status": {
            "type": "enum",
            "values": ["planning", "active", "on_hold", "completed", "archived"],
            "default": "planning"
          },
          "priority": {
            "type": "enum",
            "values": ["low", "medium", "high", "critical"],
            "default": "medium"
          },
          "start_date": { "type": "date", "required": false },
          "end_date": { "type": "date", "required": false },
          "budget": { "type": "decimal", "precision": 10, "scale": 2, "required": false },
          "tags": { "type": "json", "required": false, "default": "[]" },
          "client_name": { "type": "string", "required": false },

          "created_at": { "type": "timestamp", "auto": true },
          "updated_at": { "type": "timestamp", "auto": true }
        }
      },
      "tasks": {
        "tableName": "tasks",
        "userScoped": true,
        "fields": {
          "id": { "type": "uuid", "primaryKey": true, "auto": true },
          "title": { "type": "string", "required": true, "maxLength": 500 },
          "description": { "type": "text", "required": false },
          "project_id": {
            "type": "uuid",
            "required": true,
            "foreignKey": { "entity": "projects", "field": "id", "onDelete": "CASCADE" }
          },
          "status": {
            "type": "enum",
            "values": ["todo", "in_progress", "review", "done"],
            "default": "todo"
          },
          "priority": {
            "type": "enum",
            "values": ["low", "medium", "high", "urgent"],
            "default": "medium"
          },
          "assignee_email": { "type": "string", "required": false },
          "due_date": { "type": "date", "required": false },
          "estimated_hours": { "type": "decimal", "precision": 5, "scale": 1, "required": false },
          "labels": { "type": "json", "required": false, "default": "[]" },
          "created_at": { "type": "timestamp", "auto": true },
          "updated_at": { "type": "timestamp", "auto": true }
        }
      },
      "customers": {
        "tableName": "customers",
        "userScoped": true,
        "fields": {
          "id": { "type": "uuid", "primaryKey": true, "auto": true },
          "name": { "type": "string", "required": true, "maxLength": 255 },
          "email": { "type": "email", "required": true },
          "phone": { "type": "string", "required": false },
          "status": {
            "type": "enum",
            "values": ["lead", "active", "churned"],
            "default": "lead"
          },
          "created_at": { "type": "timestamp", "auto": true }
        }
      }
    }
  },

  "api": {
    "prefix": "/api/v1",
    "endpoints": {
      "projects": {
        "entity": "projects",
        "auth": true,
        "operations": ["list", "get", "create", "update", "delete"],
        "pagination": { "enabled": true, "defaultLimit": 20, "maxLimit": 100 },
        "search": { "enabled": true, "fields": ["name", "description"] },
        "sort": { "enabled": true, "defaultField": "created_at", "defaultOrder": "DESC" },
        "filters": {
          "status": { "type": "enum", "operator": "eq" },
          "priority": { "type": "enum", "operator": "eq" },
          "start_date": { "type": "date", "operator": "gte" }
        }
      },
      "tasks": {
        "entity": "tasks",
        "auth": true,
        "operations": ["list", "get", "create", "update", "delete"],
        "pagination": { "enabled": true, "defaultLimit": 25, "maxLimit": 100 },
        "search": { "enabled": true, "fields": ["title", "description"] },
        "sort": { "enabled": true, "defaultField": "created_at", "defaultOrder": "DESC" },
        "filters": {
          "status": { "type": "enum", "operator": "eq" },
          "priority": { "type": "enum", "operator": "eq" },
          "project_id": { "type": "uuid", "operator": "eq" },
          "due_date": { "type": "date", "operator": "lte" }
        }
      },
      "customers": {
        "entity": "customers",
        "auth": true,
        "operations": ["list", "get", "create", "update", "delete"],
        "pagination": { "enabled": true, "defaultLimit": 25, "maxLimit": 100 },
        "search": { "enabled": true, "fields": ["name", "email"] },
        "sort": { "enabled": true, "defaultField": "created_at", "defaultOrder": "DESC" },
        "filters": {
          "status": { "type": "enum", "operator": "eq" },
          "priority": { "type": "enum", "operator": "eq" },
          "project_id": { "type": "uuid", "operator": "eq" },
          "due_date": { "type": "date", "operator": "lte" }
        }
      }
    }
  },


  "ui": {
    "pages": {
      "dashboard": {
        "title": "nav.dashboard",
        "layout": "grid",
        "components": [
          {
            "type": "stats_card",
            "entity": "projects",
            "label": "nav.projects",
            "aggregation": "count"
          },
          {
            "type": "stats_card",
            "entity": "tasks",
            "label": "nav.tasks",
            "aggregation": "count"
          },
          {
            "type": "table",
            "entity": "tasks",
            "label": "Recent Tasks",
            "limit": 5,
            "columns": ["title", "status", "priority", "due_date"],
            "sort": { "field": "created_at", "order": "DESC" }
          }
        ]
      },
      "projects": {
        "title": "nav.projects",
        "layout": "table_with_form",
        "entity": "projects",
        "table": {
          "columns": ["name", "status", "priority", "start_date", "end_date", "budget"],
          "searchable": true,
          "actions": ["edit", "delete"]
        },
        "form": {
          "fields": ["name", "description", "status", "priority", "start_date", "end_date", "budget", "tags", "client_name"]
        }
      },
      "tasks": {
        "title": "nav.tasks",
        "layout": "table_with_form",
        "entity": "tasks",
        "table": {
          "columns": ["title", "status", "priority", "project_id", "assignee_email", "due_date"],
          "searchable": true,
          "actions": ["edit", "delete"]
        },
        "form": {
          "fields": ["title", "description", "project_id", "status", "priority", "assignee_email", "due_date", "estimated_hours", "labels"]
        }
      },
      "customers": {
        "title": "nav.customers",
        "layout": "table_with_form",
        "entity": "customers",
        "table": {
          "columns": ["name", "email", "phone", "status"],
          "searchable": true,
          "actions": ["edit", "delete"]
        },
        "form": {
          "fields": ["name", "email", "phone", "status"]
        }
      }
    },
    "navigation": [
      { "label": "nav.dashboard", "path": "/dashboard", "icon": "LayoutDashboard" },
      { "label": "nav.projects", "path": "/dashboard/projects", "icon": "FolderKanban" },
      { "label": "nav.tasks", "path": "/dashboard/tasks", "icon": "CheckSquare" },
      {"label": "Customers", "path": "/dashboard/customers", "icon": "Users"}
    ]
  },


  "export": {
    "github": {
      "enabled": true,
      "includeReadme": true,
      "includeDockerfile": true,
      "includeEnvExample": true
    }
  }
}
